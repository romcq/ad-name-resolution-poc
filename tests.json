{
  "description": "Tests based on the article format table, corner cases and agreed LDAP/Kerberos clarifications.",
  "tests": [
    {"id":"ldap_upn_basic","category":"ldap_basic","description":"LDAP Simple Bind: explicit userPrincipalName from BindRequest.name","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"userA@pastukhov.lab"}},"expected":{"resolved":true,"protocol":"LDAP","algorithm_branch":"LDAP Simple Authentication","matched_format":"userPrincipalName","matched_field":"userPrincipalName","matched_object_id":"userA"}},
    {"id":"ldap_downlevel_basic","category":"ldap_basic","description":"LDAP Simple Bind: Down-Level Logon Name DOMAIN\\user","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"PASTUKHOV\\userA"}},"expected":{"resolved":true,"matched_format":"downLevelLogonName","matched_field":"domainNetBIOS+sAMAccountName","matched_object_id":"userA"}},
    {"id":"ldap_dn_basic","category":"ldap_basic","description":"LDAP Simple Bind: distinguishedName wins first","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"CN=userA,CN=Users,DC=pastukhov,DC=lab"}},"expected":{"resolved":true,"matched_format":"distinguishedName","matched_field":"distinguishedName","matched_object_id":"userA"}},
    {"id":"ldap_dn_escaped_comma","category":"ldap_dn","description":"LDAP DN parser: escaped comma inside RDN must not split the DN","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"CN=user\\,A,CN=Users,DC=pastukhov,DC=lab"}},"expected":{"resolved":true,"matched_format":"distinguishedName","matched_field":"distinguishedName","matched_object_id":"dnEscapedComma"}},
    {"id":"ldap_dn_escaped_plus","category":"ldap_dn","description":"LDAP DN parser: escaped plus is accepted inside RDN","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"CN=user\\+A,CN=Users,DC=pastukhov,DC=lab"}},"expected":{"resolved":true,"matched_format":"distinguishedName","matched_object_id":"dnEscapedPlus"}},
    {"id":"ldap_dn_escaped_quote","category":"ldap_dn","description":"LDAP DN parser: escaped quote is accepted inside RDN","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"CN=user\\\"A\\\",CN=Users,DC=pastukhov,DC=lab"}},"expected":{"resolved":true,"matched_format":"distinguishedName","matched_object_id":"dnEscapedQuote"}},
    {"id":"ldap_dn_escaped_backslash","category":"ldap_dn","description":"LDAP DN parser: escaped backslash is accepted inside RDN","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"CN=user\\\\A,CN=Users,DC=pastukhov,DC=lab"}},"expected":{"resolved":true,"matched_format":"distinguishedName","matched_object_id":"dnEscapedBackslash"}},
    {"id":"ldap_dn_escaped_angle","category":"ldap_dn","description":"LDAP DN parser: escaped angle brackets are accepted inside RDN","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"CN=user\\<A\\>,CN=Users,DC=pastukhov,DC=lab"}},"expected":{"resolved":true,"matched_format":"distinguishedName","matched_object_id":"dnEscapedAngle"}},
    {"id":"ldap_dn_escaped_semicolon","category":"ldap_dn","description":"LDAP DN parser: escaped semicolon is accepted inside RDN","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"CN=user\\;A,CN=Users,DC=pastukhov,DC=lab"}},"expected":{"resolved":true,"matched_format":"distinguishedName","matched_object_id":"dnEscapedSemicolon"}},
    {"id":"ldap_dn_escaped_equals","category":"ldap_dn","description":"LDAP DN parser: escaped equals is accepted inside RDN","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"CN=user\\=A,CN=Users,DC=pastukhov,DC=lab"}},"expected":{"resolved":true,"matched_format":"distinguishedName","matched_object_id":"dnEscapedEquals"}},
    {"id":"ldap_dn_slash","category":"ldap_dn","description":"LDAP DN parser: slash inside CN does not make the value canonicalName","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"CN=user/A,CN=Users,DC=pastukhov,DC=lab"}},"expected":{"resolved":true,"matched_format":"distinguishedName","matched_object_id":"dnSlash"}},
    {"id":"ldap_dn_escaped_hash","category":"ldap_dn","description":"LDAP DN parser: escaped leading hash is accepted inside RDN","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"CN=\\#userA,CN=Users,DC=pastukhov,DC=lab"}},"expected":{"resolved":true,"matched_format":"distinguishedName","matched_object_id":"dnEscapedHash"}},
    {"id":"ldap_canonical_basic","category":"ldap_basic","description":"LDAP Simple Bind: canonicalName","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"pastukhov.lab/Users/userA"}},"expected":{"resolved":true,"matched_format":"canonicalName","matched_field":"canonicalName","matched_object_id":"userA"}},
    {"id":"ldap_guid_basic","category":"ldap_basic","description":"LDAP Simple Bind: objectGUID","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"{5c69b042-e0e9-475a-ae37-1751ef9e05e7}"}},"expected":{"resolved":true,"matched_format":"objectGUID","matched_field":"objectGUID","matched_object_id":"userA"}},
    {"id":"ldap_display_basic","category":"ldap_basic","description":"LDAP Simple Bind: displayName after earlier formats do not match","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"User A"}},"expected":{"resolved":true,"matched_format":"displayName","matched_field":"displayName","matched_object_id":"userA"}},
    {"id":"ldap_spn_basic","category":"ldap_basic","description":"LDAP Simple Bind: servicePrincipalName without earlier collision","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"domain3.lab","request":{"operation":"bindRequest","name":"HTTP/userB"}},"expected":{"resolved":true,"matched_format":"servicePrincipalName","matched_field":"servicePrincipalName","matched_object_id":"userB"}},
    {"id":"ldap_object_sid_basic","category":"ldap_basic","description":"LDAP Simple Bind: objectSid","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"domain3.lab","request":{"operation":"bindRequest","name":"S-1-5-21-3677553567-317466416-2570716728-1106"}},"expected":{"resolved":true,"matched_format":"objectSid","matched_field":"objectSid","matched_object_id":"userB"}},
    {"id":"ldap_sid_history_basic","category":"ldap_basic","description":"LDAP Simple Bind: sIDHistory","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"S-1-5-21-2845156888-2425353457-3474467337-5114"}},"expected":{"resolved":true,"matched_format":"sIDHistory","matched_field":"sIDHistory","matched_object_id":"userA"}},
    {"id":"ldap_mapspn_basic","category":"ldap_basic","description":"LDAP Simple Bind: simplified MapSPN maps HOST/userA to HTTP/userA","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"HOST/userA"}},"expected":{"resolved":true,"matched_format":"MapSPN","matched_field":"servicePrincipalName","matched_object_id":"userA"}},
    {"id":"ldap_canonical_lf_basic","category":"ldap_basic","description":"LDAP Simple Bind: canonicalName with last slash replaced by LF","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"pastukhov.lab/Users\nuserA"}},"expected":{"resolved":true,"matched_format":"canonicalNameWithLF","matched_field":"canonicalName","matched_object_id":"userA"}},
    {"id":"ldap_generated_upn_corner","category":"ldap_corner","description":"Corner: userPrincipalName is absent, generated UPN is accepted","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"userImplicit@pastukhov.lab"}},"expected":{"resolved":true,"matched_format":"generatedUPN","matched_field":"sAMAccountName+domainFQDN","matched_object_id":"userImplicit"}},
    {"id":"ldap_explicit_upn_wins_over_generated_corner","category":"ldap_corner","description":"Corner: explicit userPrincipalName wins over another object's generated UPN","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"userImplicitOwner@pastukhov.lab"}},"expected":{"resolved":true,"matched_format":"userPrincipalName","matched_field":"userPrincipalName","matched_object_id":"userConflict"}},
    {"id":"ldap_implicit_disabled_when_upn_is_set_corner","category":"ldap_corner","description":"Corner: generated UPN is not accepted when explicit userPrincipalName is set","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"userUpnSet@pastukhov.lab"}},"expected":{"resolved":false,"reason":"object_not_found"}},
    {"id":"ldap_explicit_changed_upn_corner","category":"ldap_corner","description":"Corner: explicit changed userPrincipalName is accepted as whole string","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"userUpnSetX@pastukhov.lab"}},"expected":{"resolved":true,"matched_format":"userPrincipalName","matched_object_id":"userUpnSet"}},
    {"id":"ldap_explicit_upn_custom_suffix","category":"ldap_corner","description":"Corner: explicit UPN with custom suffix is accepted as a whole userPrincipalName","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"user.custom@corp.example"}},"expected":{"resolved":true,"matched_format":"userPrincipalName","matched_object_id":"userCustomSuffix"}},
    {"id":"ldap_local_domain_priority_corner","category":"ldap_corner","description":"Corner: same explicit UPN in two domains; local domain context chooses local object","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"userTrust@pastukhov.lab"}},"expected":{"resolved":true,"matched_format":"userPrincipalName","matched_object_id":"userTrustLocal"}},
    {"id":"ldap_no_domain_context_not_unique_corner","category":"ldap_corner","description":"Corner: same explicit UPN without domain context is not unique","input":{"protocol":"LDAP","bind_kind":"simple","request":{"operation":"bindRequest","name":"userTrust@pastukhov.lab"}},"expected":{"resolved":false,"matched_format":"userPrincipalName","matched_field":"userPrincipalName","reason":"not_unique"}},
    {"id":"ldap_duplicate_display_not_unique_corner","category":"ldap_corner","description":"Corner: two users have the same displayName","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"Duplicate Display"}},"expected":{"resolved":false,"matched_format":"displayName","matched_field":"displayName","reason":"not_unique"}},
    {"id":"ldap_display_equals_sam_corner","category":"ldap_corner","description":"Corner: bare userA is not LDAP sAMAccountName; later displayName can match","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"userA"}},"expected":{"resolved":true,"matched_format":"displayName","matched_object_id":"userDisplaySam"}},
    {"id":"ldap_display_loses_to_upn_corner","category":"ldap_corner","description":"Corner: displayName equals UPN, but userPrincipalName is earlier","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"userA@pastukhov.lab"}},"expected":{"resolved":true,"matched_format":"userPrincipalName","matched_object_id":"userA"}},
    {"id":"ldap_display_loses_to_downlevel_corner","category":"ldap_corner","description":"Corner: displayName equals DOMAIN\\user, but downLevelLogonName is earlier","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"PASTUKHOV\\userA"}},"expected":{"resolved":true,"matched_format":"downLevelLogonName","matched_object_id":"userA"}},
    {"id":"ldap_display_loses_to_dn_corner","category":"ldap_corner","description":"Corner: displayName equals DN, but distinguishedName is first","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"CN=userA,CN=Users,DC=pastukhov,DC=lab"}},"expected":{"resolved":true,"matched_format":"distinguishedName","matched_object_id":"userA"}},
    {"id":"ldap_display_loses_to_canonical_corner","category":"ldap_corner","description":"Corner: displayName equals canonicalName, but canonicalName is earlier","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"pastukhov.lab/Users/userA"}},"expected":{"resolved":true,"matched_format":"canonicalName","matched_object_id":"userA"}},
    {"id":"ldap_display_loses_to_guid_corner","category":"ldap_corner","description":"Corner: displayName equals objectGUID, but objectGUID is earlier","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"{5c69b042-e0e9-475a-ae37-1751ef9e05e7}"}},"expected":{"resolved":true,"matched_format":"objectGUID","matched_object_id":"userA"}},
    {"id":"ldap_display_wins_over_spn_corner","category":"ldap_corner","description":"Corner: displayName equals servicePrincipalName; displayName is earlier than SPN","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"HTTP/userA"}},"expected":{"resolved":true,"matched_format":"displayName","matched_object_id":"userDisplaySpn"}},
    {"id":"ldap_display_wins_over_sid_corner","category":"ldap_corner","description":"Corner: displayName equals objectSid; displayName is earlier than objectSid","input":{"protocol":"LDAP","bind_kind":"simple","domain_context":"pastukhov.lab","request":{"operation":"bindRequest","name":"S-1-5-21-2845156888-2425353457-3474467337-1114"}},"expected":{"resolved":true,"matched_format":"displayName","matched_object_id":"userDisplaySid"}},
