    {"id":"krb_tgs_srv_inst_userprincipalname","category":"kerberos","description":"Kerberos TGS-REQ: NT-SRV-INST service string through userPrincipalName","input":{"protocol":"Kerberos","message_type":"TGS-REQ","sname":{"name_type":2,"name_string":["cifs","10-23-RP-DC-01.pastukhov.lab"]},"realm":"PASTUKHOV.LAB"},"expected":{"resolved":true,"algorithm_branch":"Server Principal Lookup","matched_format":"NT-SRV-INST/userPrincipalName","matched_field":"userPrincipalName","matched_object_id":"svcCifsUpn"}},
    {"id":"krb_tgs_principal_userprincipalname","category":"kerberos","description":"Kerberos TGS-REQ: NT-PRINCIPAL service-like userPrincipalName","input":{"protocol":"Kerberos","message_type":"TGS-REQ","sname":{"name_type":1,"name_string":["cifs","10-23-RP-DC-01.pastukhov.lab"]},"realm":"PASTUKHOV.LAB"},"expected":{"resolved":true,"matched_format":"NT-PRINCIPAL/userPrincipalName","matched_object_id":"svcCifsUpn"}},
    {"id":"krb_tgs_srv_hst_userprincipalname","category":"kerberos","description":"Kerberos TGS-REQ: NT-SRV-HST service-like userPrincipalName","input":{"protocol":"Kerberos","message_type":"TGS-REQ","sname":{"name_type":3,"name_string":["cifs","10-23-RP-DC-01.pastukhov.lab"]},"realm":"PASTUKHOV.LAB"},"expected":{"resolved":true,"matched_format":"NT-SRV-HST/userPrincipalName","matched_object_id":"svcCifsUpn"}},
    {"id":"krb_tgs_krbtgt_special_case","category":"kerberos","description":"Kerberos TGS-REQ: two-component krbtgt name uses second component as sAMAccountName","input":{"protocol":"Kerberos","message_type":"TGS-REQ","sname":{"name_type":2,"name_string":["krbtgt","krbtgt"]},"realm":"PASTUKHOV.LAB"},"expected":{"resolved":true,"matched_format":"NT-SRV-INST/krbtgt/sAMAccountName","matched_field":"sAMAccountName","matched_object_id":"krbtgt"}},
    {"id":"krb_tgs_srv_inst_sam_dollar","category":"kerberos","description":"Kerberos TGS-REQ: one-element service name falls back to sAMAccountName + $","input":{"protocol":"Kerberos","message_type":"TGS-REQ","sname":{"name_type":2,"name_string":["10-23-RP-DC-01"]},"realm":"PASTUKHOV.LAB"},"expected":{"resolved":true,"matched_format":"NT-SRV-INST/sAMAccountName+$","matched_field":"sAMAccountName","matched_object_id":"dc01"}},
    {"id":"krb_tgs_enterprise_spn","category":"kerberos","description":"Kerberos TGS-REQ: NT-ENTERPRISE service string checked as servicePrincipalName","input":{"protocol":"Kerberos","message_type":"TGS-REQ","sname":{"name_type":10,"name_string":["HTTP/userB"]},"realm":"DOMAIN3.LAB"},"expected":{"resolved":true,"matched_format":"NT-ENTERPRISE/servicePrincipalName","matched_field":"servicePrincipalName","matched_object_id":"userB"}},
    {"id":"krb_tgs_enterprise_fallback_without_spn_fails","category":"kerberos","description":"Kerberos TGS-REQ: NT-ENTERPRISE sAMAccountName fallback must fail without registered SPN","input":{"protocol":"Kerberos","message_type":"TGS-REQ","sname":{"name_type":10,"name_string":["userImplicit"]},"realm":"PASTUKHOV.LAB"},"expected":{"resolved":false,"algorithm_branch":"Server Principal Lookup","reason":"object_not_found"}},
    {"id":"krb_as_unsupported_name_type","category":"limitations","description":"Limitation: unsupported Kerberos client name_type is reported explicitly","input":{"protocol":"Kerberos","message_type":"AS-REQ","cname":{"name_type":6,"name_string":["1000"]},"realm":"PASTUKHOV.LAB"},"expected":{"resolved":false,"algorithm_branch":"Client Principal Lookup","reason":"unsupported_name_type"}},
    {"id":"krb_as_cracknames_not_implemented","category":"limitations","description":"Limitation: if direct AS-REQ checks fail, CrackNames is shown as not implemented","input":{"protocol":"Kerberos","message_type":"AS-REQ","cname":{"name_type":10,"name_string":["unknown@pastukhov.lab"]},"realm":"PASTUKHOV.LAB"},"expected":{"resolved":false,"algorithm_branch":"Client Principal Lookup","reason":"object_not_found","unimplemented_steps":["CrackNames"]}}
