{
  "description": "Тесты резолвера по таблицам и алгоритмам статьи. Все кейсы используют единую базу ad_snapshot.json.",
  "tests": [
    {
      "id": "ldap_sam_userA_not_accepted",
      "category": "ldap_table",
      "description": "LDAP: вход \"userA\" -> ожидаемый формат: displayName -> результат: object_not_found",
      "input": {
        "protocol": "LDAP",
        "bind_kind": "simple",
        "request": {
          "operation": "bindRequest",
          "name": "userA"
        },
        "domain_context": "pastukhov.lab"
      },
      "expected": {
        "resolved": false,
        "protocol": "LDAP",
        "algorithm_branch": "LDAP Simple Authentication",
        "reason": "object_not_found",
        "detected_format": "displayName"
      }
    },
    {
      "id": "ldap_upn_userA",
