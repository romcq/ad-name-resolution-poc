{
  "description": "Tests limited to the article tables and agreed LDAP/Kerberos clarifications.",
  "tests": [
    {
      "id": "ldap_upn_userA",
      "category": "ldap_table",
      "description": "LDAP table: userPrincipalName userA@pastukhov.lab",
      "input": {
        "protocol": "LDAP",
        "bind_kind": "simple",
        "request": {
          "operation": "bindRequest",
          "name": "userA@pastukhov.lab"
        },
        "domain_context": "pastukhov.lab"
      },
      "expected": {
        "resolved": true,
        "protocol": "LDAP",
        "algorithm_branch": "LDAP Simple Authentication",
        "matched_format": "userPrincipalName",
        "matched_field": "userPrincipalName",
        "matched_object_id": "userA"
      }
    },
    {
      "id": "ldap_upn_userB",
