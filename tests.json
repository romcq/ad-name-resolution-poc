  "tests": [
    {
      "id": "ldap_sam_userA_not_accepted",
      "category": "ldap_table",
      "snapshot": "base",
      "description": "LDAP table: plain sAMAccountName userA is not accepted as SAM",
      "input": {
        "protocol": "LDAP",
        "bind_kind": "simple",
        "request": {
          "operation": "bindRequest",
          "name": "userA"
        },
        "domain_context": "pastukhov.lab"
      },
      "expected": {
        "resolved": false,
        "protocol": "LDAP",
        "algorithm_branch": "LDAP Simple Authentication",
        "reason": "object_not_found",
        "detected_format": "displayName"
      }
    },
    {
