    {"id":"krb_as_enterprise_custom_upn_suffix","category":"kerberos","description":"Kerberos AS-REQ: NT-ENTERPRISE explicit UPN with custom suffix","input":{"protocol":"Kerberos","message_type":"AS-REQ","cname":{"name_type":10,"name_string":["user.custom@corp.example"]},"realm":"PASTUKHOV.LAB"},"expected":{"resolved":true,"matched_format":"NT-ENTERPRISE/userPrincipalName","matched_object_id":"userCustomSuffix"}},
