      },
      "expected": {
        "resolved": true,
        "protocol": "LDAP",
        "algorithm_branch": "LDAP Simple Authentication",
        "matched_format": "userPrincipalName",
        "matched_field": "userPrincipalName",
        "matched_object_id": "userA"
      }
    },
